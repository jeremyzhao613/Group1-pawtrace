# Local one-command startup uses scripts/local-db.sh on port 55432.
DATABASE_URL="postgresql://pawtrace@localhost:55432/pawtrace"

# If you use docker compose instead, switch to:
# DATABASE_URL="postgresql://pawtrace:pawtrace@localhost:5432/pawtrace"
PORT=3000
NODE_ENV=development

# JWT（生产环境务必设置强随机串）
JWT_SECRET="change-me-in-production"

# AI（仅服务端）
DASHSCOPE_API_KEY=
GEMINI_API_KEY=
AI_KEY_SECRET=
ENCRYPTED_DASHSCOPE_API_KEY=
ENCRYPTED_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_TIMEOUT_MS=15000

# 设备上报（可选）
DEVICE_TOKENS=
REQUIRE_DEVICE_TOKEN=0

# Monitor
MONITOR_API_TOKEN=
MONITOR_MAX=500
SENSOR_MAX=2000
LOCATION_LAST_MAX_AGE_MS=600000

# Keep backend as API-only by default. Set SERVE_WEB=1 only for single-port deployment.
SERVE_WEB=0

# Static web app served by backend after build when SERVE_WEB=1: frontend | glass
WEB_APP=frontend

# NFC
NFC_CARD_SECRET=
